<Window x:Class="FirmasApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirmasApp"
        mc:Ignorable="d"
        Title="App de Firmas - gedsys2"
        Height="600"
        Width="1000"
        Icon="/Assets/logo.png"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título con logo -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <!-- Logo -->
            <Image x:Name="AppLogo"
                   Width="40"
                   Height="40"
                   Margin="0,0,15,0"
                   VerticalAlignment="Center"
                   Source="/Assets/logo.png"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Effect>
                    <DropShadowEffect Color="#CCCCCC" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Image.Effect>
            </Image>

            <!-- Título -->
            <TextBlock Text="Gestión de Firmas Digitales"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Auth Header -->
        <Border Grid.Row="1"
                Background="{Binding SessionExpiringSoon, Converter={StaticResource SessionBackgroundConverter}}"
                Padding="15"
                Margin="0,0,0,10"
                CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="12" Height="12"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding IsAuthenticated, Converter={StaticResource BoolToColorConverter}}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Usuario: "/>
                        <Run Text="{Binding CurrentUserInfo, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>

                    <!-- Advertencia de sesión por expirar -->
                    <TextBlock VerticalAlignment="Center"
                               Margin="15,0,0,0"
                               FontWeight="Bold"
                               Foreground="#F44336"
                               Visibility="{Binding SessionExpiringSoon, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Run Text="⚠️ "/>
                        <Run Text="Sesión por expirar"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⚙️ Configuración"
                            x:Name="BtnConfigureGeneral"
                            Width="140"
                            Height="30"
                            Margin="0,0,10,0"
                            Background="#FF9800"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnConfigureGeneral_Click"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            ToolTip="Configurar autenticación, API y sincronización cloud"/>
                    <Button Content="🔐 Iniciar Sesión"
                            Command="{Binding LoginCommand}"
                            Width="120"
                            Height="30"
                            Margin="0,0,10,0"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Content="🚪 Cerrar Sesión"
                            Command="{Binding LogoutCommand}"
                            Width="120"
                            Height="30"
                            Background="#F44336"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>


        <!-- Buscador y botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="300"
                     Height="30"
                     Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="Busqueda_KeyDown"
                     Margin="0,0,10,0"
                     IsEnabled="{Binding IsAuthenticated}"/>
            <Button Content="🔍 Buscar"
                    Command="{Binding BuscarCommand}"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"/>
            <Button Content="🔄 Refrescar"
                    Command="{Binding LoadUsuariosCommand}"
                    Width="100"
                    Height="30"/>
        </StackPanel>

        <!-- Lista de usuarios -->
        <Border Grid.Row="4"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid ItemsSource="{Binding UsuariosFiltrados}"
                          SelectedItem="{Binding UsuarioSeleccionado}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="150"/>
                        <DataGridTextColumn Header="Nombres" Binding="{Binding Nombres}" Width="200"/>
                        <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="200"/>
                        <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="150"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                        <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo.Nombre}" Width="150"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                        <DataGridTemplateColumn Header="Estado Firma" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <!-- Indicador visual de firma -->
                                        <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding TieneFirma, Converter={StaticResource BoolToColorConverter}}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <!-- Texto de estado -->
                                        <TextBlock Text="{Binding EstadoFirma}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{Binding TieneFirma, Converter={StaticResource BoolToColorConverter}}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Acciones" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <Button Content="✍️ Firmar"
                                               Width="70" Height="25"
                                               Margin="0,0,5,0"
                                               Click="BtnFirmar_Click"
                                               Tag="{Binding}"
                                               FontSize="11"/>
                                        <Button Content="🗑️ Borrar"
                                               Width="70" Height="25"
                                               Click="BtnBorrarFirma_Click"
                                               Tag="{Binding}"
                                               FontSize="11"
                                               IsEnabled="{Binding TieneFirma}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Controles de paginación -->
                <Border Grid.Row="1"
                        Background="#F5F5F5"
                        BorderBrush="#CCCCCC"
                        BorderThickness="0,1,0,0"
                        Padding="10,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Información de paginación -->
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="#555">
                            <Run Text="📄"/>
                            <Run Text="{Binding PageInfo, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- Botones de navegación -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="⏮"
                                    Command="{Binding FirstPageCommand}"
                                    Width="35"
                                    Height="30"
                                    Margin="0,0,5,0"
                                    Background="#E0E0E0"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Primera página"/>
                            <Button Content="◀"
                                    Command="{Binding PreviousPageCommand}"
                                    Width="35"
                                    Height="30"
                                    Margin="0,0,5,0"
                                    Background="#E0E0E0"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Página anterior"/>
                            <TextBlock VerticalAlignment="Center"
                                       Margin="10,0"
                                       FontWeight="Bold">
                                <Run Text="{Binding CurrentPage, Mode=OneWay, Converter={StaticResource AddOneConverter}}"/>
                                <Run Text="de"/>
                                <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Content="▶"
                                    Command="{Binding NextPageCommand}"
                                    Width="35"
                                    Height="30"
                                    Margin="5,0,5,0"
                                    Background="#E0E0E0"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Página siguiente"/>
                            <Button Content="⏭"
                                    Command="{Binding LastPageCommand}"
                                    Width="35"
                                    Height="30"
                                    Background="#E0E0E0"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Última página"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Estadísticas de firmas -->
        <Border Grid.Row="5"
               Background="#E3F2FD"
               Padding="15,10"
               CornerRadius="5"
               Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 " FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="Con firma: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding UsuariosConFirmaCount, Mode=OneWay}"
                          FontWeight="Bold"
                          Foreground="#2196F3"
                          VerticalAlignment="Center"
                          FontSize="14"
                          Margin="0,0,15,0"/>
                <TextBlock Text="| Sin firma: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding UsuariosSinFirmaCount, Mode=OneWay}"
                          FontWeight="Bold"
                          Foreground="#F44336"
                          VerticalAlignment="Center"
                          FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Overlay de carga -->
        <Grid Grid.RowSpan="6"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <TextBlock Text="Cargando..."
                           FontSize="20"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <ProgressBar Width="200"
                            Height="5"
                            IsIndeterminate="True"
                            Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
