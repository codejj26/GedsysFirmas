<Window x:Class="FirmasApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirmasApp"
        mc:Ignorable="d"
        Title="App de Firmas - gedsys2" Height="600" Width="1000"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0"
                   Text="Gestión de Firmas Digitales"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- Auth Header -->
        <Border Grid.Row="1"
                Background="#E8F5E9"
                Padding="15"
                Margin="0,0,0,10"
                CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="12" Height="12"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding IsAuthenticated, Converter={StaticResource BoolToColorConverter}}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Usuario: "/>
                        <Run Text="{Binding CurrentUserInfo, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="🔐 Iniciar Sesión"
                            Command="{Binding LoginCommand}"
                            Width="120"
                            Height="30"
                            Margin="0,0,10,0"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Content="🚪 Cerrar Sesión"
                            Command="{Binding LogoutCommand}"
                            Width="120"
                            Height="30"
                            Background="#F44336"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Estado de conexión -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                Padding="10"
                Margin="0,0,0,10"
                CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Buscador y botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="300"
                     Height="30"
                     Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="Busqueda_KeyDown"
                     Margin="0,0,10,0"
                     IsEnabled="{Binding IsAuthenticated}"/>
            <Button Content="🔍 Buscar"
                    Command="{Binding BuscarCommand}"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"/>
            <Button Content="🔄 Recargar"
                    Command="{Binding LoadUsuariosCommand}"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"/>
            <Button Content="✍️ Gestionar Firmas"
                    Command="{Binding GestionarFirmaCommand}"
                    Width="140"
                    Height="30"
                    Background="#9C27B0"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Lista de usuarios -->
        <Border Grid.Row="4"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="5">
            <DataGrid ItemsSource="{Binding UsuariosFiltrados}"
                      SelectedItem="{Binding UsuarioSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="150"/>
                    <DataGridTextColumn Header="Nombres" Binding="{Binding Nombres}" Width="200"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="200"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo.Nombre}" Width="150"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                    <DataGridTemplateColumn Header="Estado Firma" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <!-- Indicador visual de firma -->
                                    <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding TieneFirma, Converter={StaticResource BoolToColorConverter}}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Texto de estado -->
                                    <TextBlock Text="{Binding EstadoFirma}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{Binding TieneFirma, Converter={StaticResource BoolToColorConverter}}"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Acciones" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Button Content="✍️ Firmar"
                                           Width="70" Height="25"
                                           Margin="0,0,5,0"
                                           Click="BtnFirmar_Click"
                                           Tag="{Binding}"
                                           FontSize="11"/>
                                    <Button Content="🗑️ Borrar"
                                           Width="70" Height="25"
                                           Click="BtnBorrarFirma_Click"
                                           Tag="{Binding}"
                                           FontSize="11"
                                           IsEnabled="{Binding TieneFirma}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Barra de estado y acciones -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Estadísticas de firmas -->
            <Border Grid.Column="0"
                   Background="#E3F2FD"
                   Padding="10,5"
                   CornerRadius="3"
                   Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊 " FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Con firma: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding UsuariosConFirmaCount, Mode=OneWay}"
                              FontWeight="Bold"
                              Foreground="#2196F3"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    <TextBlock Text="| Sin firma: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding UsuariosSinFirmaCount, Mode=OneWay}"
                              FontWeight="Bold"
                              Foreground="#F44336"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- TextBlock central -->
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       TextAlignment="Center">
                <Run Text="Usuarios: "/>
                <Run Text="{Binding UsuariosFiltrados.Count, Mode=OneWay}"/>
                <Run Text=" | Seleccionado: "/>
                <Run Text="{Binding UsuarioSeleccionado.NombreCompleto, Mode=OneWay}"/>
            </TextBlock>

            <!-- Botón de acción principal -->
            <Button Grid.Column="2"
                    Content="✍️ Gestionar Firmas"
                    Command="{Binding GestionarFirmaCommand}"
                    Width="150"
                    Height="35"
                    Background="#9C27B0"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,0"/>
        </Grid>

        <!-- Overlay de carga -->
        <Grid Grid.RowSpan="6"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <TextBlock Text="Cargando..."
                           FontSize="20"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <ProgressBar Width="200"
                            Height="5"
                            IsIndeterminate="True"
                            Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
