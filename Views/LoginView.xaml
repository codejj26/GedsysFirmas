<Window x:Class="FirmasApp.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirmasApp.Views"
        mc:Ignorable="d"
        Title="Firmas App - Iniciar Sesión"
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo/Icon -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
            <TextBlock Text="✍️" FontSize="64" TextAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Text="Gestión de Firmas Digitales"
                       FontSize="24"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Login Content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Para continuar, debe iniciar sesión con su cuenta de gedsys"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       Opacity="0.7"/>

            <TextBlock Text="Se abrirá su navegador predeterminado para completar la autenticación"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30"
                       FontSize="14"
                       Opacity="0.6"/>

            <!-- Login Button -->
            <Button Command="{Binding LoginCommand}"
                    Width="200"
                    Height="40"
                    HorizontalAlignment="Center"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔐 " Margin="0,0,10,0"/>
                    <TextBlock Text="Iniciar Sesión"/>
                </StackPanel>
            </Button>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       TextAlignment="Center"
                       Margin="0,20,0,0"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#666"/>
        </StackPanel>

        <!-- Loading Indicator -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Procesando..."
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <ProgressBar Width="150"
                            Height="5"
                            IsIndeterminate="True"
                            Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
