<Window x:Class="FirmasApp.Views.GestionFirmaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:FirmasApp.Components"
        mc:Ignorable="d"
        Title="Capturar Firma"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título con logo -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="15,10" Margin="0,0,0,15" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <Image Width="32"
                       Height="32"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Source="/Assets/logo.png"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Capturar Firma"
                          FontSize="18"
                          FontWeight="SemiBold"
                          Foreground="#333"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Info del usuario actual -->
        <Border Grid.Row="1" Background="#FAFAFA" Padding="12,8" Margin="0,0,0,15" CornerRadius="3" BorderBrush="#E0E0E0" BorderThickness="1">
            <TextBlock x:Name="TxtUsuario"
                      Text="{Binding UsuarioActual}"
                      FontWeight="Medium"
                      FontSize="14"
                      Foreground="#555"
                      VerticalAlignment="Center"/>
        </Border>

        <!-- Canvas de firma -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="3"
                Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                          Text="Firme aquí (use mouse o tableta Wacom)"
                          Foreground="#888"
                          FontSize="12"
                          Margin="0,0,0,10"/>

                <components:FirmaCanvas
                    x:Name="FirmaCanvasControl"
                    Grid.Row="1"
                    Height="280"/>
            </Grid>
        </Border>

        <!-- Barra de estado y botones -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Mensaje de estado -->
            <TextBlock x:Name="TxtStatus"
                      Grid.Column="0"
                      Text="Listo"
                      Foreground="#666"
                      FontSize="12"
                      VerticalAlignment="Center"
                      Visibility="Collapsed"/>

            <!-- Botones de acción - todos alineados a la derecha -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Botones secundarios -->
                <Button x:Name="BtnLimpiar"
                       Content="Limpiar"
                       Width="90" Height="32"
                       Margin="0,0,8,0"
                       Background="#F5F5F5"
                       Foreground="#555"
                       BorderThickness="1"
                       BorderBrush="#D0D0D0"
                       Cursor="Hand"
                       Click="BtnLimpiar_Click"/>

                <Button x:Name="BtnWacom"
                       Content="Usar Dispositivo"
                       Width="90" Height="32"
                       Margin="0,0,8,0"
                       Background="#F5F5F5"
                       Foreground="#555"
                       BorderThickness="1"
                       BorderBrush="#D0D0D0"
                       Cursor="Hand"
                       Click="BtnWacom_Click"/>

                <!-- Separador visual -->
                <Border Width="1"
                       Background="#D0D0D0"
                       Margin="5,0"/>

                <!-- Botones principales -->
                <Button x:Name="BtnGuardarFirma"
                       Content="Guardar"
                       Width="90" Height="32"
                       Margin="0,0,8,0"
                       Background="#2196F3"
                       Foreground="White"
                       BorderThickness="0"
                       Cursor="Hand"
                       Click="BtnGuardarFirma_Click"/>

                <Button x:Name="BtnEliminarFirma"
                       Content="Eliminar"
                       Width="90" Height="32"
                       Background="#F44336"
                       Foreground="White"
                       BorderThickness="0"
                       Cursor="Hand"
                       Click="BtnEliminarFirma_Click"/>
            </StackPanel>
        </Grid>

        <!-- Overlay de carga -->
        <Grid Grid.RowSpan="4"
              Background="#80000000"
              x:Name="LoadingOverlay"
              Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Procesando..."
                          FontSize="18"
                          Foreground="White"
                          Margin="0,0,0,10"/>
                <ProgressBar Width="200" Height="5" IsIndeterminate="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>