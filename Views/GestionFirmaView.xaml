<Window x:Class="FirmasApp.Views.GestionFirmaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:FirmasApp.Components"
        mc:Ignorable="d"
        Title="Gestión de Firmas"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título y selección de usuario -->
        <Border Grid.Row="0" Background="#E8F5E9" Padding="15" Margin="0,0,0,15" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Gestión de Firmas" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnCargarFirma"
                           Content="Cargar Firma"
                           Width="120" Height="30"
                           Margin="0,0,5,0"
                           Click="BtnCargarFirma_Click"/>
                    <Button x:Name="BtnGuardarFirma"
                           Content="Guardar"
                           Width="100" Height="30"
                           Margin="0,0,5,0"
                           Click="BtnGuardarFirma_Click"/>
                    <Button x:Name="BtnEliminarFirma"
                           Content="Eliminar"
                           Width="100" Height="30"
                           Click="BtnEliminarFirma_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Info del usuario actual -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,15" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Usuario:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1"
                          x:Name="TxtUsuario"
                          Text="{Binding UsuarioActual}"
                          FontWeight="Bold"
                          VerticalAlignment="Center"
                          Foreground="#2196F3"/>

                <Ellipse Grid.Column="2" Width="12" Height="12" VerticalAlignment="Center" Fill="#FF0000"/>
            </Grid>
        </Border>

        <!-- Canvas de firma -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                          Text="Capture su firma aquí (use mouse o tablet Wacom)"
                          Foreground="#666"
                          Margin="0,0,0,10"/>

                <components:FirmaCanvas
                    x:Name="FirmaCanvasControl"
                    Grid.Row="1"
                    Height="250"/>
            </Grid>
        </Border>

        <!-- Barra de estado -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                   Background="#FFF3CD"
                   BorderBrush="#FFC107"
                   BorderThickness="1"
                   CornerRadius="3"
                   Padding="10,5"
                   Visibility="Collapsed">
                <TextBlock x:Name="TxtStatus"
                          Text="Listo"
                          Foreground="#856404"/>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnLimpiar"
                       Content="Limpiar Canvas"
                       Width="120" Height="30"
                       Margin="0,0,5,0"
                       Click="BtnLimpiar_Click"/>
                <Button x:Name="BtnWacom"
                       Content="Usar Wacom"
                       Width="120" Height="30"
                       Click="BtnWacom_Click"/>
            </StackPanel>
        </Grid>

        <!-- Overlay de carga -->
        <Grid Grid.RowSpan="4"
              Background="#80000000"
              x:Name="LoadingOverlay"
              Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Procesando..."
                          FontSize="18"
                          Foreground="White"
                          Margin="0,0,0,10"/>
                <ProgressBar Width="200" Height="5" IsIndeterminate="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>