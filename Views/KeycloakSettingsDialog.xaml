<Window x:Class="FirmasApp.Views.KeycloakSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirmasApp.Views"
        mc:Ignorable="d"
        Title="Configuración de Keycloak"
        Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⚙️" FontSize="48" TextAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Text="Configuración de Keycloak"
                       FontSize="24"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Contenido de configuración -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- URL de Keycloak -->
                <TextBlock Text="URL del Servidor Keycloak"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtKeycloakUrl"
                         Height="30"
                         Padding="5"
                         Margin="0,0,0,15"
                         Text="https://keycloak.gedsys.co"/>

                <!-- Realm -->
                <TextBlock Text="Realm"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtRealm"
                         Height="30"
                         Padding="5"
                         Margin="0,0,0,15"
                         Text="development"/>

                <!-- Client ID -->
                <TextBlock Text="Client ID"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtClientId"
                         Height="30"
                         Padding="5"
                         Margin="0,0,0,15"
                         Text="gedsys-firmas"/>

                <!-- Redirect URI -->
                <TextBlock Text="Redirect URI"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtRedirectUri"
                         Height="30"
                         Padding="5"
                         Margin="0,0,0,15"
                         Text="firmasapp://callback"/>

                <!-- Sección de notas -->
                <Border Background="#FFF3E0"
                        Padding="15"
                        CornerRadius="5"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="📝 Notas de Configuración"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="• La URL debe incluir el protocolo (https://)"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="• El realm debe existir en Keycloak"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="• El Client ID debe estar configurado en Keycloak"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="• El Redirect URI debe estar registrado en Keycloak"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="• Para development: https://keycloak.gedsys.co"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"
                                       Foreground="#2196F3"/>
                            <TextBlock Text="• Para producción: verificar con el equipo de infraestructura"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"
                                       Foreground="#F44336"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Información de configuración actual -->
                <Border Background="#E8F5E9"
                        Padding="15"
                        CornerRadius="5"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Información Actual"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock>
                                <Run Text="URL Base: "/>
                                <Run x:Name="TxtCurrentUrl" Text="https://keycloak.gedsys.co" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="Realm: "/>
                                <Run x:Name="TxtCurrentRealm" Text="development" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="Client ID: "/>
                                <Run x:Name="TxtCurrentClientId" Text="gedsys-firmas" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Botones -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="BtnReset"
                    Content="🔄 Restablecer Valores"
                    Width="150"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#FF9800"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnReset_Click"/>
            <Button x:Name="BtnSave"
                    Content="💾 Guardar Configuración"
                    Width="150"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnCancel"
                    Content="❌ Cancelar"
                    Width="120"
                    Height="35"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
