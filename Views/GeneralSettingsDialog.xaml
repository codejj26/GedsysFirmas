<Window x:Class="FirmasApp.Views.GeneralSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FirmasApp.Views"
        mc:Ignorable="d"
        Title="Configuración General"
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⚙️" FontSize="48" TextAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Text="Configuración General"
                       FontSize="24"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Pestañas de configuración -->
        <TabControl Grid.Row="1" Background="Transparent">
            <!-- Pestaña: Autenticación (Keycloak) -->
            <TabItem Header="🔐 Autenticación">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Configuración de Keycloak"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,15"/>

                        <!-- URL de Keycloak -->
                        <TextBlock Text="URL del Servidor Keycloak"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtKeycloakUrl"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Realm -->
                        <TextBlock Text="Realm"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtRealm"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Client ID -->
                        <TextBlock Text="Client ID"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtClientId"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Redirect URI -->
                        <TextBlock Text="Redirect URI"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtRedirectUri"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Información actual -->
                        <Border Background="#E8F5E9"
                                Padding="15"
                                CornerRadius="5"
                                Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Configuración Actual"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock>
                                        <Run Text="URL: "/>
                                        <Run x:Name="TxtCurrentKeycloakUrl" FontWeight="Bold"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="Realm: "/>
                                        <Run x:Name="TxtCurrentRealm" FontWeight="Bold"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="Client ID: "/>
                                        <Run x:Name="TxtCurrentClientId" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Pestaña: API (GedsysApi) -->
            <TabItem Header="🌐 API">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Configuración de API"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,15"/>

                        <!-- Base URL -->
                        <TextBlock Text="URL Base de la API"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtApiBaseUrl"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Timeout -->
                        <TextBlock Text="Timeout (segundos)"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtApiTimeout"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Token de autenticación -->
                        <TextBlock Text="Token de Autenticación (opcional)"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtApiToken"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Información actual -->
                        <Border Background="#E3F2FD"
                                Padding="15"
                                CornerRadius="5"
                                Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Configuración Actual"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock>
                                        <Run Text="URL: "/>
                                        <Run x:Name="TxtCurrentApiBaseUrl" FontWeight="Bold"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="Timeout: "/>
                                        <Run x:Name="TxtCurrentApiTimeout" FontWeight="Bold"/>
                                        <Run Text=" segundos"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Notas -->
                        <Border Background="#FFF3E0"
                                Padding="15"
                                CornerRadius="5"
                                Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="📝 Notas"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" Margin="10,0,0,0">
                                    <Run Text="• La URL base debe incluir el protocolo (https://)" Foreground="#555"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="10,5,0,0">
                                    <Run Text="• El token se usa para autenticación adicional si es requerida" Foreground="#555"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Pestaña: Cloud (Supabase) -->
            <TabItem Header="☁️ Cloud">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Configuración de Supabase"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,15"/>

                        <!-- Habilitar Supabase -->
                        <CheckBox x:Name="ChkSupabaseEnabled"
                                  Content="Habilitar sincronización con Supabase"
                                  Margin="0,0,0,15"/>

                        <!-- Host -->
                        <TextBlock Text="Host"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtSupabaseHost"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Puerto -->
                        <TextBlock Text="Puerto"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtSupabasePort"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Database -->
                        <TextBlock Text="Base de Datos"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtSupabaseDatabase"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Username -->
                        <TextBlock Text="Usuario"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtSupabaseUsername"
                                 Height="30"
                                 Padding="5"
                                 Margin="0,0,0,15"/>

                        <!-- Password -->
                        <TextBlock Text="Contraseña"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="TxtSupabasePassword"
                                    Height="30"
                                    Padding="5"
                                    Margin="0,0,0,15"/>

                        <!-- Botón de prueba -->
                        <Button Content="🧪 Probar Conexión"
                                Width="150"
                                Height="35"
                                Margin="0,10,0,0"
                                Background="#2196F3"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnTestSupabase_Click"
                                HorizontalAlignment="Left"/>

                        <!-- Información actual -->
                        <Border Background="#F3E5F5"
                                Padding="15"
                                CornerRadius="5"
                                Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Configuración Actual"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock>
                                        <Run Text="Host: "/>
                                        <Run x:Name="TxtCurrentSupabaseHost" FontWeight="Bold"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="Puerto: "/>
                                        <Run x:Name="TxtCurrentSupabasePort" FontWeight="Bold"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="Estado: "/>
                                        <Run x:Name="TxtCurrentSupabaseStatus" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Botones -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="BtnReset"
                    Content="🔄 Restablecer"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#FF9800"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnReset_Click"/>
            <Button x:Name="BtnSave"
                    Content="💾 Guardar"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnCancel"
                    Content="❌ Cancelar"
                    Width="120"
                    Height="35"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>