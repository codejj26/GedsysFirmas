<Window x:Class="FirmasApp.Views.SupabaseSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de Supabase - Sincronización Cloud"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F5F5F5">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="CheckStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Border Padding="30" Background="White" CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="⚙️ Configuración de Supabase"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#1976D2"
                           Margin="0,0,0,20"/>

                <!-- Descripción -->
                <TextBlock Text="Supabase proporciona sincronización automática con PostgreSQL en la nube."
                           FontSize="11" Foreground="#757575"
                           Margin="0,0,0,20" TextWrapping="Wrap"/>

                <!-- Habilitar Sincronización Cloud -->
                <CheckBox x:Name="ChkEnabled"
                          Content="Habilitar sincronización con Supabase"
                          Style="{StaticResource CheckStyle}"
                          IsChecked="False"/>

                <!-- Host -->
                <TextBlock Text="Host (ej: db.xxx.supabase.co):"
                           Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtHost"
                         Style="{StaticResource InputStyle}"
                         Text=""/>

                <!-- Puerto -->
                <TextBlock Text="Puerto (default: 5432):"
                           Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtPort"
                         Style="{StaticResource InputStyle}"
                         Text="5432"/>

                <!-- Database -->
                <TextBlock Text="Base de Datos (default: postgres):"
                           Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtDatabase"
                         Style="{StaticResource InputStyle}"
                         Text="postgres"/>

                <!-- Username -->
                <TextBlock Text="Usuario (default: postgres):"
                           Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtUsername"
                         Style="{StaticResource InputStyle}"
                         Text="postgres"/>

                <!-- Password -->
                <TextBlock Text="Contraseña:"
                           Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="TxtPassword"
                            Height="30"
                            Padding="8"
                            BorderBrush="#BDBDBD"
                            BorderThickness="1"
                            Background="White"
                            Margin="0,0,0,15"
                            FontSize="12"/>

                <!-- Instrucciones -->
                <Border Background="#E3F2FD" Padding="15" CornerRadius="5" Margin="0,10,0,20">
                    <StackPanel>
                        <TextBlock Text="📋 Instrucciones:" FontWeight="Bold" FontSize="13" Foreground="#1976D2"/>
                        <TextBlock Text="1. Crea una cuenta en supabase.com (gratis)" FontSize="11" Margin="0,5,0,0"/>
                        <TextBlock Text="2. Crea un nuevo proyecto" FontSize="11"/>
                        <TextBlock Text="3. Ve a Settings → Database" FontSize="11"/>
                        <TextBlock Text="4. Copia la cadena de conexión o los datos individuales" FontSize="11"/>
                        <TextBlock Text="5. Pega los datos aquí y habilita la sincronización" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Botones -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnProbar" Content="🔍 Probar Conexión"
                            Click="BtnProbar_Click"
                            Width="140" Height="35" Margin="0,0,10,0"
                            Background="#2196F3" Foreground="White"
                            BorderThickness="0" FontSize="12"
                            Cursor="Hand"/>

                    <Button x:Name="BtnGuardar" Content="💾 Guardar Configuración"
                            Click="BtnGuardar_Click"
                            Width="160" Height="35"
                            Background="#4CAF50" Foreground="White"
                            BorderThickness="0" FontSize="12"
                            Cursor="Hand"/>

                    <Button x:Name="BtnCancelar" Content="❌ Cancelar"
                            Click="BtnCancelar_Click"
                            Width="100" Height="35" Margin="10,0,0,0"
                            Background="#F44336" Foreground="White"
                            BorderThickness="0" FontSize="12"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- Status -->
                <TextBlock x:Name="TxtStatus"
                           Text=""
                           FontSize="11" Foreground="#757575"
                           Margin="0,15,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>