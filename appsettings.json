{
  "Keycloak": {
    "Url": "https://keycloak.gedsys.co",
    "Realm": "development",
    "ClientId": "gedsys-firmas",
    "RedirectUri": "firmasapp://callback",
    "AuthorizationEndpoint": "/protocol/openid-connect/auth",
    "TokenEndpoint": "/protocol/openid-connect/token",
    "Scope": "openid profile email"
  },
  "GedsysApi": {
    "BaseUrl": "https://api.development.gedsys.app",
    "TimeoutSeconds": 30
  },
  "Supabase": {
    "Host": "db.xxx.supabase.co",
    "Port": 5432,
    "Database": "postgres",
    "Username": "postgres",
    "Password": "your-password-here",
    "Enabled": false
  },
  "WacomStu": {
    "EnableBiometricData": true,
    "AutoConnect": true,
    "DllPath": "libs/wgssSTU.dll",
    "ConnectionTimeoutMs": 5000,
    "CaptureTimeoutSeconds": 30,
    "EnablePressure": true,
    "MinPressureThreshold": 10,
    "AutoDisconnectOnIdle": false,
    "IdleTimeoutSeconds": 300,
    "SignatureWidth": 1024,
    "SignatureHeight": 600,
    "UseSimulation": false
  }
}
